-- SimpleLib: A clean, easy-to-use Roblox UI Library
-- Usage is much simpler than most libs

local SimpleLib = {}
SimpleLib.flags = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Theme
local Theme = {
	Background  = Color3.fromRGB(18, 18, 18),
	Surface     = Color3.fromRGB(26, 26, 26),
	Elevated    = Color3.fromRGB(34, 34, 34),
	Accent      = Color3.fromRGB(220, 60, 60),
	AccentHover = Color3.fromRGB(240, 80, 80),
	Border      = Color3.fromRGB(50, 50, 50),
	Text        = Color3.fromRGB(240, 240, 240),
	TextMuted   = Color3.fromRGB(140, 140, 140),
	Success     = Color3.fromRGB(60, 200, 100),
}

-- Utility: create a Roblox instance with properties
local function New(class, props, parent)
	local inst = Instance.new(class)
	for k, v in pairs(props) do
		inst[k] = v
	end
	if parent then inst.Parent = parent end
	return inst
end

-- Utility: tween a property
local function Tween(inst, props, t)
	TweenService:Create(inst, TweenInfo.new(t or 0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

-- Utility: rounded ImageLabel background trick
local function RoundFrame(parent, color, size, position, zindex)
	return New("ImageLabel", {
		Size = size or UDim2.fromScale(1, 1),
		Position = position or UDim2.new(),
		BackgroundTransparency = 1,
		Image = "rbxassetid://3570695787",
		ImageColor3 = color or Theme.Surface,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		ZIndex = zindex or 1,
		Parent = parent
	})
end

-- Drag support
local function MakeDraggable(handle, target)
	local dragging, dragStart, startPos
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = target.Position
		end
	end)
	handle.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			target.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, math.max(-36, startPos.Y.Offset + delta.Y)
			)
		end
	end)
end

------------------------------------------------------------------------
-- CreateWindow(title, options?)
-- options: { position = UDim2, width = number }
------------------------------------------------------------------------
function SimpleLib:CreateWindow(title, options)
	options = options or {}

	local width  = options.width or 240
	local gui    = New("ScreenGui", { Name = "SimpleLib", ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling })

	-- protect gui
	if syn and syn.protect_gui then syn.protect_gui(gui)
	elseif gethui then gui.Parent = gethui()
	else gui.Parent = game:GetService("CoreGui") end

	-- main frame
	local main = RoundFrame(gui, Theme.Background,
		UDim2.new(0, width, 0, 36),
		options.position or UDim2.new(0, 40, 0, 40)
	)
	main.ClipsDescendants = true

	-- title bar
	local titleBar = RoundFrame(main, Theme.Surface, UDim2.new(1, 0, 0, 36))
	New("TextLabel", {
		Size = UDim2.new(1, -36, 1, 0),
		Position = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Text = title,
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		TextColor3 = Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 2,
		Parent = titleBar
	})

	-- collapse button
	local collapsed = false
	local contentHeight = 0
	local colBtn = New("TextButton", {
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -30, 0, 6),
		BackgroundTransparency = 1,
		Text = "▾",
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		TextColor3 = Theme.TextMuted,
		ZIndex = 3,
		Parent = titleBar
	})
	colBtn.MouseButton1Click:Connect(function()
		collapsed = not collapsed
		colBtn.Text = collapsed and "▸" or "▾"
		Tween(main, { Size = UDim2.new(0, width, 0, collapsed and 36 or 36 + contentHeight) }, 0.2)
	end)

	-- content scroll frame
	local content = New("ScrollingFrame", {
		Position = UDim2.new(0, 0, 0, 36),
		Size = UDim2.new(1, 0, 1, -36),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Theme.Border,
		CanvasSize = UDim2.new(),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		ZIndex = 2,
		Parent = main
	})

	local layout = New("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 1),
		Parent = content
	})
	New("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), Parent = content })

	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		contentHeight = layout.AbsoluteContentSize.Y + 8
		if not collapsed then
			main.Size = UDim2.new(0, width, 0, 36 + contentHeight)
		end
	end)

	MakeDraggable(titleBar, main)

	-- Window object returned to user
	local win = { _content = content, _order = 0, _main = main }

	------------------------------------------------------------------------
	-- :Label(text)
	------------------------------------------------------------------------
	function win:Label(text)
		local row = New("Frame", {
			LayoutOrder = self._order,
			Size = UDim2.new(1, 0, 0, 28),
			BackgroundTransparency = 1,
			ZIndex = 2,
			Parent = self._content
		})
		New("TextLabel", {
			Size = UDim2.new(1, -16, 1, 0),
			Position = UDim2.new(0, 10, 0, 0),
			BackgroundTransparency = 1,
			Text = text,
			Font = Enum.Font.Gotham,
			TextSize = 13,
			TextColor3 = Theme.TextMuted,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 3,
			Parent = row
		})
		self._order += 1
		local obj = { _label = row:FindFirstChildWhichIsA("TextLabel") }
		function obj:Set(t) self._label.Text = t end
		return obj
	end

	------------------------------------------------------------------------
	-- :Toggle(text, default?, callback?)
	------------------------------------------------------------------------
	function win:Toggle(text, default, callback)
		default  = default  or false
		callback = callback or function() end

		local state = default
		SimpleLib.flags[text] = state

		local row = New("Frame", {
			LayoutOrder = self._order,
			Size = UDim2.new(1, 0, 0, 34),
			BackgroundTransparency = 1,
			ZIndex = 2,
			Parent = self._content
		})
		New("TextLabel", {
			Size = UDim2.new(1, -46, 1, 0),
			Position = UDim2.new(0, 10, 0, 0),
			BackgroundTransparency = 1,
			Text = text,
			Font = Enum.Font.Gotham,
			TextSize = 14,
			TextColor3 = Theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 3,
			Parent = row
		})

		local box = RoundFrame(row, state and Theme.Accent or Theme.Elevated,
			UDim2.new(0, 22, 0, 22),
			UDim2.new(1, -30, 0.5, -11), 3
		)
		local check = New("TextLabel", {
			Size = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			Text = "✓",
			Font = Enum.Font.GothamBold,
			TextSize = 14,
			TextColor3 = Theme.Text,
			TextTransparency = state and 0 or 1,
			ZIndex = 4,
			Parent = box
		})

		local btn = New("TextButton", {
			Size = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			Text = "",
			ZIndex = 5,
			Parent = row
		})

		local function refresh()
			Tween(box, { ImageColor3 = state and Theme.Accent or Theme.Elevated })
			Tween(check, { TextTransparency = state and 0 or 1 })
		end

		btn.MouseButton1Click:Connect(function()
			state = not state
			SimpleLib.flags[text] = state
			refresh()
			callback(state)
		end)

		self._order += 1
		local obj = { state = state }
		function obj:Set(s)
			state = s
			self.state = s
			SimpleLib.flags[text] = s
			refresh()
			callback(s)
		end
		return obj
	end

