--[[
    UILibrary.lua  –  Accurate recreation of "Rc Hub" style
    =========================================================
    USAGE:
        local lib = loadstring(...)()
        local win = lib:CreateWindow("Rc Hub", "🍀2x Luck🍀", "Sailor Piece - 08/03/2026")

        local farmTab = win:AddTab("Farm")
        local g = farmTab:AddGroup("Player Support")

        g:AddToggle({ text="Auto Haki",  desc="Automatically Equip Haki", flag="autoHaki",  callback=function(v) end })
        g:AddToggle({ text="Speed hack", flag="speedHack", callback=function(v) end })

        g:AddSlider({ text="Distance Farm", desc="Distance Player To Mob",
                      min=0, max=100, value=13, flag="distFarm", callback=function(v) end })

        g:AddDropdown({ text="Select Weapon", values={"Sword","Gun","Fruit"},
                        flag="weapon", callback=function(v) end })
        g:AddButton({ text="Refresh Weapon", callback=function() end })

        g:AddLabel({ text='<font color="#ff4444">!! FOUND BUG? JOIN DISCORD !!</font>' })

        local sub = g:AddCollapsible("Farm Level")
        sub:AddLabel({ text="This Mode Will Start Auto Farm" })
        sub:AddToggle({ text="Auto Farm Max Level", flag="autoFarm", callback=function(v) end })
]]

local Library = { flags={}, windows={} }

-- ── Services ──────────────────────────────────────────────────────────────────
local TW   = game:GetService("TweenService")
local UIS  = game:GetService("UserInputService")
local TS   = game:GetService("TextService")

-- ── Tween shorthand ───────────────────────────────────────────────────────────
local function tw(o,p,t)
    TW:Create(o,TweenInfo.new(t or 0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),p):Play()
end

-- ── Instance factory ──────────────────────────────────────────────────────────
local function new(cls, props, parent)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do o[k]=v end
    if parent then o.Parent=parent end
    return o
end
local function corner(r,p) return new("UICorner",{CornerRadius=UDim.new(0,r)},p) end

-- ── Colours (sampled from screenshots) ───────────────────────────────────────
local BG        = Color3.fromRGB(15, 20, 30)    -- window bg
local SIDEBAR   = Color3.fromRGB(11, 15, 24)    -- left sidebar
local CONTENT   = Color3.fromRGB(19, 25, 37)    -- right content
local ROW       = Color3.fromRGB(22, 29, 43)    -- item row
local ROW_HOV   = Color3.fromRGB(28, 37, 55)    -- row hover
local TITLEBAR  = Color3.fromRGB(9,  13, 21)    -- top bar
local GRP_HDR   = Color3.fromRGB(16, 22, 34)    -- group label bg
local COLPS_BG  = Color3.fromRGB(20, 27, 40)    -- collapsible header
local INNER_BG  = Color3.fromRGB(16, 21, 33)    -- collapsible inner bg
local SEP_RED   = Color3.fromRGB(190, 30, 30)   -- red separator
local ACCENT    = Color3.fromRGB(215, 40, 40)   -- red accent
local ON_COL    = Color3.fromRGB(215, 40, 40)   -- toggle on
local OFF_COL   = Color3.fromRGB(50,  62, 84)   -- toggle off
local WHITE     = Color3.fromRGB(255,255,255)
local SUBTEXT   = Color3.fromRGB(110,122,148)
local TAB_ACT   = Color3.fromRGB(20, 27, 41)    -- active tab bg
local DROP_BG   = Color3.fromRGB(15, 20, 32)    -- dropdown bg
local SEP_LINE  = Color3.fromRGB(10, 14, 22)    -- row separator

-- ── Drag ──────────────────────────────────────────────────────────────────────
local _drag, _dragStart, _startPos, _dragObj
UIS.InputChanged:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseMovement and _drag and _dragObj then
        local d=i.Position-_dragStart
        _dragObj.Position=UDim2.new(_startPos.X.Scale,_startPos.X.Offset+d.X,_startPos.Y.Scale,_startPos.Y.Offset+d.Y)
    end
end)
local function draggable(handle, frame)
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            _drag=true; _dragObj=frame; _dragStart=i.Position; _startPos=frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then _drag=false end
    end)
end

-- ══════════════════════════════════════════════════════════════════════════════
--   CreateWindow(title, subtitle, tag)
--   title    = "Rc Hub"
--   subtitle = "🍀2x Luck🍀"   → white in titlebar
--   tag      = "Sailor Piece - 08/03/2026"  → red in titlebar
-- ══════════════════════════════════════════════════════════════════════════════
function Library:CreateWindow(title, subtitle, tag)
    subtitle = subtitle or ""; tag = tag or ""

    local gui = new("ScreenGui",{Name="UILib",ResetOnSpawn=false,ZIndexBehavior=Enum.ZIndexBehavior.Sibling,IgnoreGuiInset=true})
    -- Protect and parent the gui safely across all executors
    pcall(function()
        if syn and syn.protect_gui then
            syn.protect_gui(gui)
        end
    end)
    local parented = false
    pcall(function()
        if gethui then
            gui.Parent = gethui()
            parented = true
        end
    end)
    if not parented then
        pcall(function()
            gui.Parent = game:GetService("CoreGui")
            parented = true
        end)
    end
    if not parented then
        gui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    end

    -- ── Main frame 660×430 ──
    local main = new("Frame",{
        Name="Main", Size=UDim2.new(0,660,0,430),
        Position=UDim2.new(0.5,-330,0.5,-215),
        BackgroundColor3=BG, BorderSizePixel=0, ClipsDescendants=false,
        Parent=gui,
    })
    corner(8,main)

    -- Shadow
    new("ImageLabel",{
        Size=UDim2.new(1,40,1,40), Position=UDim2.new(0,-20,0,-20),
        BackgroundTransparency=1,
        Image="rbxassetid://1316045217",
        ImageColor3=Color3.new(0,0,0), ImageTransparency=0.55,
        ScaleType=Enum.ScaleType.Slice, SliceCenter=Rect.new(10,10,118,118),
        ZIndex=0, Parent=main,
    })

    -- ── Title bar 32px ──
    local tbar = new("Frame",{
        Size=UDim2.new(1,0,0,32), BackgroundColor3=TITLEBAR,
        BorderSizePixel=0, ZIndex=2, Parent=main,
    })
    corner(8,tbar)
    -- flatten bottom corners
    new("Frame",{Size=UDim2.new(1,0,0,8),Position=UDim2.new(0,0,1,-8),BackgroundColor3=TITLEBAR,BorderSizePixel=0,ZIndex=2,Parent=tbar})

    -- Red left accent in titlebar
    new("Frame",{Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,10,0.5,-8),BackgroundColor3=ACCENT,BorderSizePixel=0,ZIndex=3,Parent=tbar})

    -- Title RichText label
    local parts = string.format('<font color="#ffffff">%s</font>', title)
    if subtitle~="" then parts = parts..string.format(' <font color="#888888">‖</font> <font color="#ffffff">%s</font>', subtitle) end
    if tag~=""      then parts = parts..string.format(' <font color="#888888">‖</font> <font color="#cc3333"> %s</font>', tag) end

    new("TextLabel",{
        Position=UDim2.new(0,20,0,0), Size=UDim2.new(1,-70,1,0),
        BackgroundTransparency=1, RichText=true,
        Text=parts, TextSize=12, Font=Enum.Font.GothamSemibold,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3, Parent=tbar,
    })

    -- Window buttons
    for i,data in ipairs({{txt="─",xOff=-60},{txt="✕",xOff=-30}}) do
        local b=new("TextButton",{
            Size=UDim2.new(0,26,0,26), Position=UDim2.new(1,data.xOff,0.5,-13),
            BackgroundTransparency=1, Text=data.txt,
            TextColor3=SUBTEXT, TextSize=13, Font=Enum.Font.GothamBold,
            ZIndex=3, Parent=tbar,
        })
        b.MouseEnter:Connect(function() tw(b,{TextColor3=WHITE}) end)
        b.MouseLeave:Connect(function() tw(b,{TextColor3=SUBTEXT}) end)
        b.MouseButton1Click:Connect(function() Library:Toggle() end)
    end
    draggable(tbar, main)

    -- ── Body (below titlebar) ──
    local body = new("Frame",{
        Position=UDim2.new(0,0,0,32), Size=UDim2.new(1,0,1,-32),
        BackgroundTransparency=1, BorderSizePixel=0, ClipsDescendants=true,
        Parent=main,
    })

    -- ── Sidebar 130px wide ──
    local sidebar = new("Frame",{
        Size=UDim2.new(0,130,1,0), BackgroundColor3=SIDEBAR,
        BorderSizePixel=0, Parent=body,
    })
    -- right edge line
    new("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,-1,0,0),BackgroundColor3=Color3.fromRGB(7,10,18),BorderSizePixel=0,Parent=sidebar})

    local sideLayout = new("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0),Parent=sidebar})
    new("UIPadding",{PaddingTop=UDim.new(0,6),Parent=sidebar})

    -- ── Content 530px wide ──
    local contentArea = new("Frame",{
        Position=UDim2.new(0,130,0,0), Size=UDim2.new(1,-130,1,0),
        BackgroundColor3=CONTENT, BorderSizePixel=0, ClipsDescendants=true,
        Parent=body,
    })

    -- Page title label at top of content
    local pageTitle = new("TextLabel",{
        Size=UDim2.new(1,0,0,46),
        BackgroundColor3=CONTENT, BorderSizePixel=0,
        Text="", TextColor3=WHITE, TextSize=22,
        Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=2, Parent=contentArea,
    })
    new("UIPadding",{PaddingLeft=UDim.new(0,14),Parent=pageTitle})
    -- bottom border of page title area
    new("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=Color3.fromRGB(28,36,52),BorderSizePixel=0,ZIndex=2,Parent=pageTitle})

    -- ── Window table ──────────────────────────────────────────────────────────
    local window={gui=gui,main=main,sidebar=sidebar,contentArea=contentArea,tabs={},activeTab=nil}

    -- ════════════════════════════════════════════════════════════════════════
    --  AddTab(name)
    -- ════════════════════════════════════════════════════════════════════════
    function window:AddTab(name)
        local btn = new("TextButton",{
            LayoutOrder=#self.tabs+1,
            Size=UDim2.new(1,-2,0,36),
            BackgroundColor3=SIDEBAR, BorderSizePixel=0,
            Text="", ZIndex=2, Parent=sidebar,
        })

        -- left red indicator bar
        local indicator = new("Frame",{
            Size=UDim2.new(0,3,0.52,0), Position=UDim2.new(0,0,0.24,0),
            BackgroundColor3=ACCENT, BorderSizePixel=0,
            Visible=false, ZIndex=3, Parent=btn,
        })

        -- ‖ double-bar icon (like in screenshots)
        local bar1=new("Frame",{Size=UDim2.new(0,2,0,13),Position=UDim2.new(0,14,0.5,-6.5),BackgroundColor3=SUBTEXT,BorderSizePixel=0,ZIndex=3,Parent=btn})
        local bar2=new("Frame",{Size=UDim2.new(0,2,0,13),Position=UDim2.new(0,19,0.5,-6.5),BackgroundColor3=SUBTEXT,BorderSizePixel=0,ZIndex=3,Parent=btn})

        local nameLbl = new("TextLabel",{
            Position=UDim2.new(0,28,0,0), Size=UDim2.new(1,-32,1,0),
            BackgroundTransparency=1,
            Text=name, TextSize=13, Font=Enum.Font.GothamSemibold,
            TextColor3=SUBTEXT, TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=3, Parent=btn,
        })

        -- Scroll page for this tab
        local page = new("ScrollingFrame",{
            Position=UDim2.new(0,0,0,46), Size=UDim2.new(1,0,1,-46),
            BackgroundTransparency=1, BorderSizePixel=0,
            ScrollBarThickness=3, ScrollBarImageColor3=ACCENT,
            ScrollingDirection=Enum.ScrollingDirection.Y,
            CanvasSize=UDim2.new(0,0,0,0),
            Visible=false, ZIndex=2, Parent=contentArea,
        })
        local pageLayout=new("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0),Parent=page})
        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize=UDim2.new(0,0,0,pageLayout.AbsoluteContentSize.Y+6)
        end)

        local tab={name=name,btn=btn,nameLbl=nameLbl,indicator=indicator,bar1=bar1,bar2=bar2,page=page,groups={}}

        local function activate()
            for _,t in ipairs(window.tabs) do
                tw(t.nameLbl,{TextColor3=SUBTEXT})
                tw(t.btn,{BackgroundColor3=SIDEBAR})
                t.indicator.Visible=false
                t.bar1.BackgroundColor3=SUBTEXT
                t.bar2.BackgroundColor3=SUBTEXT
                t.page.Visible=false
            end
            tw(nameLbl,{TextColor3=WHITE})
            tw(btn,{BackgroundColor3=TAB_ACT})
            indicator.Visible=true
            bar1.BackgroundColor3=WHITE; bar2.BackgroundColor3=WHITE
            page.Visible=true
            pageTitle.Text=name
            window.activeTab=tab
        end

        btn.MouseButton1Click:Connect(activate)
        btn.MouseEnter:Connect(function() if window.activeTab~=tab then tw(btn,{BackgroundColor3=Color3.fromRGB(16,21,33)}) end end)
        btn.MouseLeave:Connect(function() if window.activeTab~=tab then tw(btn,{BackgroundColor3=SIDEBAR}) end end)

        table.insert(self.tabs,tab)
        if #self.tabs==1 then activate() end

        -- ══════════════════════════════════════════════════════════════════
        --  AddGroup(groupName)
        --  Creates a bold header + red underline separator, then flat rows
        -- ══════════════════════════════════════════════════════════════════
        function tab:AddGroup(groupName)
            local group={items={}}

            -- Group header
            local gHdr=new("Frame",{
                LayoutOrder=#self.groups*100,
                Size=UDim2.new(1,0,0,30),
                BackgroundColor3=GRP_HDR, BorderSizePixel=0, ZIndex=2,
                Parent=page,
            })
            new("TextLabel",{
                Position=UDim2.new(0,14,0,0), Size=UDim2.new(1,-20,1,0),
                BackgroundTransparency=1,
                Text=groupName, TextSize=14, Font=Enum.Font.GothamBold,
                TextColor3=WHITE, TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=3, Parent=gHdr,
            })
            -- red line at bottom of header
            new("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=SEP_RED,BorderSizePixel=0,ZIndex=3,Parent=gHdr})

            -- Item container
            local ctr=new("Frame",{
                LayoutOrder=#self.groups*100+1,
                Size=UDim2.new(1,0,0,0),
                BackgroundColor3=CONTENT, BorderSizePixel=0,
                ClipsDescendants=false, ZIndex=2, Parent=page,
            })
            local ctrL=new("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0),Parent=ctr})
            ctrL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                ctr.Size=UDim2.new(1,0,0,ctrL.AbsoluteContentSize.Y)
            end)

            table.insert(self.groups,group)

            -- ── row factory ──────────────────────────────────────────────
            local function mkRow(h, parent, bg)
                bg = bg or ROW
                local r=new("Frame",{
                    LayoutOrder=#group.items+1,
                    Size=UDim2.new(1,0,0,h),
                    BackgroundColor3=bg, BorderSizePixel=0, ZIndex=2,
                    Parent=parent or ctr,
                })
                new("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=SEP_LINE,BorderSizePixel=0,ZIndex=2,Parent=r})
                r.MouseEnter:Connect(function() tw(r,{BackgroundColor3=ROW_HOV}) end)
                r.MouseLeave:Connect(function() tw(r,{BackgroundColor3=bg}) end)
                return r
            end

            -- ── Toggle ───────────────────────────────────────────────────
            function group:AddToggle(opt)
                opt=opt or {}
                opt.text=tostring(opt.text or "Toggle"); opt.desc=tostring(opt.desc or "")
                opt.state=opt.state==true; opt.flag=opt.flag or opt.text
                opt.callback=type(opt.callback)=="function" and opt.callback or function()end
                Library.flags[opt.flag]=opt.state

                local h=opt.desc~="" and 52 or 38
                local row=mkRow(h)

                -- Red left accent bar when ON
                local lbar=new("Frame",{Size=UDim2.new(0,3,1,0),BackgroundColor3=ACCENT,BackgroundTransparency=opt.state and 0 or 1,BorderSizePixel=0,ZIndex=3,Parent=row})

                local ny=opt.desc~="" and 9 or 0
                local nLbl=new("TextLabel",{
                    Position=UDim2.new(0,16,0,ny), Size=UDim2.new(1,-68,0,20),
                    BackgroundTransparency=1,
                    Text=opt.text, TextSize=14, Font=Enum.Font.GothamSemibold,
                    TextColor3=opt.state and ACCENT or WHITE,
                    TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3, Parent=row,
                })
                if opt.desc~="" then
                    new("TextLabel",{
                        Position=UDim2.new(0,16,0,29), Size=UDim2.new(1,-68,0,14),
                        BackgroundTransparency=1,
                        Text=opt.desc, TextSize=11, Font=Enum.Font.Gotham,
                        TextColor3=SUBTEXT, TextXAlignment=Enum.TextXAlignment.Left,
                        ZIndex=3, Parent=row,
                    })
                end

                -- Pill  42×22
                local pill=new("Frame",{
                    Size=UDim2.new(0,42,0,22), Position=UDim2.new(1,-54,0.5,-11),
                    BackgroundColor3=opt.state and ON_COL or OFF_COL,
                    BorderSizePixel=0, ZIndex=4, Parent=row,
                })
                corner(11,pill)
                local knob=new("Frame",{
                    Size=UDim2.new(0,16,0,16),
                    Position=opt.state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8),
                    BackgroundColor3=WHITE, BorderSizePixel=0, ZIndex=5, Parent=pill,
                })
                corner(8,knob)

                local function setState(s)
                    opt.state=s; Library.flags[opt.flag]=s
                    tw(pill,{BackgroundColor3=s and ON_COL or OFF_COL})
                    tw(knob,{Position=s and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)})
                    tw(nLbl,{TextColor3=s and ACCENT or WHITE})
                    tw(lbar,{BackgroundTransparency=s and 0 or 1})
                    opt.callback(s)
                end

                row.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then setState(not opt.state) end
                end)
                function opt:SetState(s) setState(s) end
                table.insert(group.items,opt); return opt
            end

            -- ── Slider ───────────────────────────────────────────────────
            function group:AddSlider(opt)
                opt=opt or {}
                opt.text=tostring(opt.text or "Slider"); opt.desc=tostring(opt.desc or "")
                opt.min=tonumber(opt.min) or 0; opt.max=tonumber(opt.max) or 100
                opt.value=math.clamp(tonumber(opt.value) or opt.min,opt.min,opt.max)
                opt.float=tonumber(opt.float) or 1; opt.flag=opt.flag or opt.text
                opt.callback=type(opt.callback)=="function" and opt.callback or function()end
                Library.flags[opt.flag]=opt.value

                local row=mkRow(52)

                new("TextLabel",{Position=UDim2.new(0,16,0,8),Size=UDim2.new(0.55,0,0,20),BackgroundTransparency=1,Text=opt.text,TextSize=14,Font=Enum.Font.GothamSemibold,TextColor3=WHITE,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
                if opt.desc~="" then
                    new("TextLabel",{Position=UDim2.new(0,16,0,27),Size=UDim2.new(0.6,0,0,14),BackgroundTransparency=1,Text=opt.desc,TextSize=11,Font=Enum.Font.Gotham,TextColor3=SUBTEXT,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
                end

                -- Value (right side bold)
                local vLbl=new("TextLabel",{Position=UDim2.new(1,-96,0,8),Size=UDim2.new(0,40,0,20),BackgroundTransparency=1,Text=tostring(opt.value),TextSize=14,Font=Enum.Font.GothamBold,TextColor3=WHITE,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=3,Parent=row})

                -- Track  (right side, vertically centred)
                local trk=new("Frame",{Position=UDim2.new(1,-88,0.5,2),Size=UDim2.new(0,76,0,4),BackgroundColor3=Color3.fromRGB(38,48,68),BorderSizePixel=0,ZIndex=3,Parent=row})
                corner(2,trk)
                local p0=(opt.value-opt.min)/(opt.max-opt.min)
                local fill=new("Frame",{Size=UDim2.new(p0,0,1,0),BackgroundColor3=ACCENT,BorderSizePixel=0,ZIndex=4,Parent=trk})
                corner(2,fill)
                local knob=new("Frame",{Size=UDim2.new(0,12,0,12),Position=UDim2.new(p0,-6,0.5,-6),BackgroundColor3=ACCENT,BorderSizePixel=0,ZIndex=5,Parent=trk})
                corner(6,knob)

                local sliding=false
                local function setV(v)
                    v=math.floor(v/opt.float+0.5)*opt.float; v=math.clamp(v,opt.min,opt.max)
                    opt.value=v; Library.flags[opt.flag]=v
                    local p=(v-opt.min)/(opt.max-opt.min)
                    tw(fill,{Size=UDim2.new(p,0,1,0)},0.05); tw(knob,{Position=UDim2.new(p,-6,0.5,-6)},0.05)
                    vLbl.Text=tostring(v); opt.callback(v)
                end
                trk.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; setV(opt.min+((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X)*(opt.max-opt.min)) end end)
                UIS.InputChanged:Connect(function(i) if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then setV(opt.min+((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X)*(opt.max-opt.min)) end end)
                UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)

                function opt:SetValue(v) setV(v) end
                table.insert(group.items,opt); return opt
            end

            -- ── Dropdown ─────────────────────────────────────────────────
            -- Row: [  Label text              Select Option  ▾  ]
            function group:AddDropdown(opt)
                opt=opt or {}
                opt.text=tostring(opt.text or ""); opt.values=type(opt.values)=="table" and opt.values or {}
                opt.value=tostring(opt.value or (opt.values[1] or "Select Option"))
                opt.flag=opt.flag or opt.text; opt.open=false
                opt.callback=type(opt.callback)=="function" and opt.callback or function()end
                Library.flags[opt.flag]=opt.value

                local row=mkRow(38); row.ClipsDescendants=false; row.ZIndex=5

                if opt.text~="" then
                    new("TextLabel",{Position=UDim2.new(0,16,0,0),Size=UDim2.new(0.48,0,1,0),BackgroundTransparency=1,Text=opt.text,TextSize=14,Font=Enum.Font.GothamSemibold,TextColor3=WHITE,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,Parent=row})
                end

                -- Right chip
                local chip=new("Frame",{Position=UDim2.new(1,-152,0.5,-14),Size=UDim2.new(0,142,0,28),BackgroundColor3=DROP_BG,BorderSizePixel=0,ZIndex=6,Parent=row})
                corner(4,chip)
                new("UIStroke",{Color=Color3.fromRGB(32,42,62),Thickness=1,Parent=chip})
                local vLbl=new("TextLabel",{Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-26,1,0),BackgroundTransparency=1,Text=opt.value,TextSize=12,Font=Enum.Font.Gotham,TextColor3=SUBTEXT,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=chip})
