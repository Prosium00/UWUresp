                    end
                    chip.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then if opt.open then cd() else od() end end end)
                    function opt:SetValue(v) opt.value=tostring(v); Library.flags[opt.flag]=opt.value; vl.Text=opt.value; opt.callback(opt.value) end
                    function opt:SetValues(vals) opt.values=vals end
                    table.insert(csec.items,opt); return opt
                end

                table.insert(group.items,csec); return csec
            end -- AddCollapsible

            return group
        end -- AddGroup

        return tab
    end -- AddTab

    table.insert(Library.windows,window)
    return window
end -- CreateWindow

-- ── Toggle ────────────────────────────────────────────────────────────────────
Library.open=true
function Library:Toggle()
    self.open=not self.open
    for _,w in ipairs(self.windows) do
        if w.main then w.main.Visible=self.open end
    end
end

return Library
